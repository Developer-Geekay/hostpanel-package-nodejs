#!/bin/bash
# hp-nodejs-deploy -- root helper for the HostPanel Node.js deploy pipeline.
#
# Installed root-owned 0755 to /opt/hostpanel/bin by the plugin lifecycle;
# the package sudoers grants this single fixed path instead of raw
# ln/mv/test/readlink/ls, so root file operations are confined to
# <app_root>/{releases,current,previous} with validated arguments.
#
# Exit codes: 0 ok, 10 release/link missing, 11 manifest missing,
#             12 validation error, 13 release already exists.

die() { echo "hp-nodejs-deploy: $1" >&2; exit "${2:-12}"; }

cmd="$1"
root="$2"

case "$root" in
  /home/*) ;;
  *) die "app_root must be an absolute path under /home" ;;
esac
case "$root" in
  *..*) die "app_root must not contain .." ;;
esac
[ -d "$root" ] || die "app_root does not exist"
real="$(realpath "$root")" || die "cannot resolve app_root"
case "$real" in
  /home/*) ;;
  *) die "app_root resolves outside /home" ;;
esac

releases="$real/releases"
current="$real/current"
previous="$real/previous"

check_sha() {
  echo "$1" | grep -Eq '^[0-9a-f]{7,40}$' || die "invalid sha"
}

relink() {
  # $1=link $2=target; ln onto a temp name + mv -T keeps the swap atomic.
  ln -sfn "$2" "$1.tmp" || die "relink failed" 1
  mv -T "$1.tmp" "$1" || die "relink failed" 1
}

case "$cmd" in
  has-release)
    check_sha "$3"
    [ -d "$releases/$3" ] || exit 10
    [ -f "$releases/$3/manifest.json" ] || exit 11
    exit 0
    ;;
  has-current)
    [ -L "$current" ] || exit 10
    exit 0
    ;;
  current-target)
    if [ -L "$current" ]; then readlink "$current"; fi
    exit 0
    ;;
  list-releases)
    if [ -d "$releases" ]; then ls -1 "$releases"; fi
    exit 0
    ;;
  install-release)
    # install-release <app_root> <sha> <staged_dir> <owner>
    # Moves an extracted release from the plugin staging area into
    # releases/<sha> and hands ownership to the app's user. Releases are
    # immutable: an existing target is refused, never replaced.
    check_sha "$3"
    src="$4"
    owner="$5"
    echo "$owner" | grep -Eq '^[a-z_][a-z0-9_-]*$' || die "invalid owner"
    case "$src" in
      /opt/hostpanel/plugins/nodejs/staging/*) ;;
      *) die "source must be under the plugin staging directory" ;;
    esac
    case "$src" in
      *..*) die "source must not contain .." ;;
    esac
    [ -d "$src" ] || die "source directory does not exist"
    srcreal="$(realpath "$src")" || die "cannot resolve source"
    case "$srcreal" in
      /opt/hostpanel/plugins/nodejs/staging/*) ;;
      *) die "source resolves outside staging" ;;
    esac
    if [ -e "$releases/$3" ]; then exit 13; fi
    mkdir -p "$releases"
    mv -T "$srcreal" "$releases/$3" || die "move into releases failed" 1
    chown -R "$owner:$owner" "$releases/$3" || die "chown failed" 1
    exit 0
    ;;
  activate)
    check_sha "$3"
    [ -d "$releases/$3" ] || exit 10
    [ -f "$releases/$3/manifest.json" ] || exit 11
    old=""
    if [ -L "$current" ]; then old="$(readlink "$current")"; fi
    if [ -n "$old" ] && [ "$old" != "releases/$3" ]; then
      relink "$previous" "$old"
    fi
    relink "$current" "releases/$3"
    # Old target on stdout so the caller can record previous_sha.
    echo "$old"
    exit 0
    ;;
  *)
    die "unknown command: $cmd"
    ;;
esac
